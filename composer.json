{
    "name": "ntoufoudis/gatekeeper",
    "description": "Permissions as code for Laravel",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "permissions",
        "roles"
    ],
    "homepage": "https://github.com/ntoufoudis/gatekeeper",
    "support": {
        "issues": "https://github.com/ntoufoudis/gatekeeper/issues"
    },
    "authors": [
        {
            "name": "Vasileios Ntoufoudis",
            "email": "info@ntoufoudis.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/auth": "^11.0|^12.0|^13.0",
        "illuminate/console": "^11.0|^12.0|^13.0",
        "illuminate/events": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "laravel/pint": "^1.14",
        "larastan/larastan": "^3.0",
        "pestphp/pest": "^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0",
        "orchestra/testbench": "^9.0|^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "Ntoufoudis\\Gatekeeper\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ntoufoudis\\Gatekeeper\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Ntoufoudis\\Gatekeeper\\GatekeeperServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "test": "vendor/bin/pest",
        "analyse": "vendor/bin/phpstan analyse --memory-limit=2G",
        "test-coverage": "vendor/bin/pest --parallel --coverage",
        "format": "vendor/bin/pint"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
